#include <stdio.h>
#include <math.h>
#include <locale.h>
int main(){
	setlocale(LC_ALL, "Portuguese");
	double a, b, c, x1, x2;
	double delta;
	float escolha;
	printf("Qual valor de A:");
	scanf("%lf", &a);
 	printf("Qual valor de B:");
	scanf("%lf", &b);
	printf("Qual valor de C:");
	scanf("%lf", &c);
	
	delta = pow(b, 2) - (4 * a * c);
	if (delta == 0){
		printf("A equação possui duas raízes reais e iguais.\n");
	}
	if (delta > 0){
		printf("A equação possui duas raízes reais e distintas.\n");
	}
	if (delta < 0){
		printf(" A equação não possui raízes reais.\n");
	}
	printf("Digite (1) descobrir X1 e X2?");
	scanf("%f", &escolha);
	x1 = (-b + sqrt(delta)) / (2 * a);
	x2 = (-b - sqrt(delta)) / (2 * a);	
		if (escolha == 1){
			printf("X1 = %.2lf\n", x1);
			printf("X2 = %.2lf\n", x2);
		}
		else{
			printf("Obrigado, tchau!");
		}
	return 0;
}
